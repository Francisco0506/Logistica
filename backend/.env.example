# Copia este archivo a .env y llena los valores reales en cada máquina.
# .env NUNCA se sube a git (ver .gitignore) — hay que configurarlo a mano
# en cada computadora donde corra el backend.

# Base de datos Postgres (si no está, el backend cae solo a SQLite)
DB_NAME=laben_routing
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# OSRM propio (Docker). Si se deja vacío, usa el servidor público de demo.
OSRM_BASE=http://localhost:5001

# Samsara (GPS/telemetría de la flotilla). Generar en:
# Samsara > Configuración > Desarrollador > Tokens de API > Agregar un token de API
SAMSARA_API_TOKEN=

# Conexión a SAP B1 (SQL Server). Si se deja vacío, sync_from_sap reporta
# "SAP no configurado" en vez de inventar pedidos.
SAP_DB_HOST=
SAP_DB_NAME=
SAP_DB_USER=
SAP_DB_PASSWORD=
SAP_DB_PORT=1433

# Nombres de los UDF (campos definidos por usuario) en SAP B1 — solo si
# difieren de los defaults ya usados en sync.py.
# SAP_UDF_LATITUDE=U_Latitud
# SAP_UDF_LONGITUDE=U_Longitud
# SAP_UDF_HORA_INI1=U_IniRecibo1
# SAP_UDF_HORA_FIN1=U_FinRecibo1
